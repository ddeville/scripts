#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" && pwd)"
source "$script_dir/../lib/python-toolchain.bash"

version="$(uv python pin --global 2>/dev/null || true)"
if [ -z "$version" ]; then
  echo "No global uv Python is pinned. Run: pyswitch <python-request>" >&2
  exit 1
fi

mkdir -p "$(basename "$PYTHON_TOOLCHAIN_REQUIREMENTS_FILE")" && touch "$PYTHON_TOOLCHAIN_REQUIREMENTS_FILE"
"${EDITOR:-vi}" "$PYTHON_TOOLCHAIN_REQUIREMENTS_FILE"

python_toolchain_sync_global_venv "$version" --allow-existing
