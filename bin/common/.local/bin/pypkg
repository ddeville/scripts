#!/bin/bash

set -eu -o pipefail

python_request="$(uv python pin --global 2>/dev/null || true)"
if [ -z "$python_request" ]; then
  echo "No global uv Python is pinned. Run: pyswitch <python-request>" >&2
  exit 1
fi

global_dir="$XDG_TOOLCHAINS_HOME/python/global"
mkdir -p "$global_dir"

requirements_file="$global_dir/requirements.txt"
touch "$requirements_file"
"${EDITOR:-vi}" "$requirements_file"

global_venv="$global_dir/venv"
env -u VIRTUAL_ENV uv venv --allow-existing --python "$python_request" "$global_venv"
env -u VIRTUAL_ENV uv pip install --upgrade --refresh --python "$global_venv/bin/python" --requirements "$requirements_file"
