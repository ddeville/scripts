#!/bin/bash

set -eu -o pipefail

if [ $# -ne 1 ]; then
  echo "Usage: pyswitch <1.2.3|latest|system>"
  exit 1
fi

version="$1"

if [[ $version == "system" ]]; then
  bin_dir="$(uv python dir --bin 2>/dev/null || true)"
  if [ -n "$bin_dir" ]; then
    rm -f "$bin_dir/python" "$bin_dir/python3"
  fi
  uv python pin --global --rm >/dev/null 2>&1 || true
  echo "Using system python from PATH"
  exit 0
fi

if [[ $version == "latest" ]]; then
  version="$(uv python list --only-downloads --output-format text |
    awk '/^cpython-[0-9]+\.[0-9]+\.[0-9]+-/{sub(/^cpython-/, "", $1); sub(/-.*/, "", $1); print $1}' |
    sort -V |
    tail -n 1)"
  if [ -z "$version" ]; then
    echo "Could not resolve latest CPython version from uv." >&2
    exit 1
  fi
fi

uv python install --default "$version" --preview-features python-install-default
uv python pin --global "$version"

global_dir="$XDG_TOOLCHAINS_HOME/python/global"
mkdir -p "$global_dir"

requirements_file="$global_dir/requirements.txt"
touch "$requirements_file"

global_venv="$global_dir/venv"
env -u VIRTUAL_ENV uv venv --clear --python "$version" "$global_venv"
env -u VIRTUAL_ENV uv pip install --upgrade --python "$global_venv/bin/python" --requirements "$requirements_file"

echo "Global uv Python pin is now $(uv python pin --global)"
