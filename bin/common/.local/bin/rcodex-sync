#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" && pwd)"
source "$script_dir/../lib/rcodex.bash"

usage() {
  cat <<'EOF'
Usage: rcodex-sync <host>

Sync this repo's Codex config, helpers, and owned skills to a remote host.

Environment:
  REMOTE_PORT  Remote app-server port used for restart hints; default: 17338
  REMOTE_CODEX_HOME  Remote Codex home; default: .codex under the remote home

Examples:
  rcodex-sync host
  REMOTE_PORT=17339 rcodex-sync host
  REMOTE_CODEX_HOME=/tmp/rcodex-sync-test rcodex-sync host
EOF
}

die() {
  echo "rcodex: $*" >&2
  exit 1
}

stage_codex_config() {
  stage_home=$(mktemp -d "${TMPDIR:-/tmp}/rcodex-sync.XXXXXX")
  stow --restow --no-folding "${config_dirs[@]}" --dir "$repo_dir/config" --target "$stage_home"
}

remote_codex_home_script() {
  cat <<EOF
codex_home=$(rcodex_shell_quote "$remote_codex_home")
case "\$codex_home" in
  /*) ;;
  *) codex_home="\$HOME/\$codex_home" ;;
esac
EOF
}

remote_prepare_script() {
  cat <<EOF
if ! command -v rsync >/dev/null 2>&1; then
  echo "rcodex: remote rsync binary not found" >&2
  exit 127
fi

$(remote_codex_home_script)

mkdir -p "\$codex_home"
EOF
}

remote_render_script() {
  local restart_command

  restart_command="rcodex-stop $(rcodex_format_shell_arg "$host")"
  if [[ ${REMOTE_PORT-} != "" ]]; then
    restart_command="REMOTE_PORT=$(rcodex_format_shell_arg "$REMOTE_PORT") $restart_command"
  fi

  cat <<EOF
$(remote_codex_home_script)

port_is_open() {
  (exec 3<>"/dev/tcp/127.0.0.1/\$port") >/dev/null 2>&1
}

if [[ ! -x "\$codex_home/bin/render-config" ]]; then
  echo "rcodex: remote render-config is missing or not executable" >&2
  exit 1
fi

CODEX_HOME="\$codex_home" "\$codex_home/bin/render-config"

if port_is_open; then
  echo $(rcodex_shell_quote "rcodex: remote codex app-server is running; restart it with: $restart_command") >&2
fi
EOF
}

sync_codex() {
  local rsync_dest rsync_ssh script status

  stage_codex_config
  control_path=$(rcodex_make_control_path)
  rcodex_start_control_master "$host" "$control_path" || exit 1

  script=$(remote_prepare_script)
  rcodex_run_remote "prepare remote codex directory" "$host" "$script" "$control_path" || exit 1

  rsync_dest="$host:$remote_codex_home/"
  rsync_ssh="ssh -F none -S $(rcodex_format_shell_arg "$control_path")"

  echo "rcodex: syncing staged .codex to $host:$remote_codex_home" >&2

  set +e
  rsync -azL -e "$rsync_ssh" --rsync-path="PATH=\"\$HOME/.local/bin:\$HOME/bin:\$PATH\" rsync" "$stage_home/.codex/" "$rsync_dest"
  status=$?
  set -e

  if ((status != 0)); then
    die "failed to rsync staged .codex to $host:$remote_codex_home (rsync status $status)"
  fi

  script=$(remote_render_script)
  RCODEX_PRINT_REMOTE_OUTPUT=1 rcodex_run_remote "render remote codex config" "$host" "$script" "$control_path" || exit 1

  echo "rcodex: synced $host" >&2
}

if [[ ${1-} == "-h" || ${1-} == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -eq 1 ]] || {
  usage >&2
  die "host is required"
}

if [[ $1 == -* ]]; then
  usage >&2
  die "host is required"
fi

host=$1
repo_dir="$(cd -- "$script_dir/../../../.." && pwd)"
config_dirs=(common)
remote_codex_home=${REMOTE_CODEX_HOME:-.codex}
control_path=
stage_home=

cleanup() {
  if [[ $control_path != "" ]]; then
    rcodex_stop_control_master "$host" "$control_path"
    rm -f "$control_path"
  fi
  if [[ $stage_home != "" ]]; then
    rm -rf "$stage_home"
  fi
}

trap cleanup EXIT
trap 'trap - EXIT; cleanup; exit 130' INT
trap 'trap - EXIT; cleanup; exit 143' TERM

plat="$(uname)"
if [[ $plat == "Linux" ]]; then
  config_dirs+=(linux)
elif [[ $plat == "Darwin" ]]; then
  config_dirs+=(macos)
fi

if [[ -d $repo_dir/config/openai ]]; then
  config_dirs+=(openai)
fi

if ! command -v rsync >/dev/null 2>&1; then
  die "local rsync binary not found"
fi

if ! command -v stow >/dev/null 2>&1; then
  die "local stow binary not found"
fi

sync_codex
