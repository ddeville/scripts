#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck disable=SC1091
source "$script_dir/../lib/rcodex.bash"

usage() {
  cat <<'EOF'
Usage: rcodex-sync <host>

Sync this repo's Codex config, helpers, and owned skills to a remote host.

Environment:
  REMOTE_PORT  Remote app-server port used for restart hints; default: 17338

Examples:
  rcodex-sync host
  REMOTE_PORT=17339 rcodex-sync host
EOF
}

die() {
  echo "rcodex-sync: $*" >&2
  exit 1
}

stage_codex_config() {
  stage_home=$(mktemp -d "${TMPDIR:-/tmp}/rcodex-sync.XXXXXX")
  stow --restow --no-folding "${config_dirs[@]}" --dir "$repo_dir/config" --target "$stage_home"
}

remote_prepare_script() {
  cat <<'EOF'
if ! command -v rsync >/dev/null 2>&1; then
  echo "rcodex-sync: remote rsync binary not found" >&2
  exit 127
fi

mkdir -p "$HOME/.codex"
EOF
}

remote_render_script() {
  local restart_command

  restart_command="rcodex-stop $(rcodex_format_shell_arg "$host")"
  if [[ ${REMOTE_PORT-} != "" ]]; then
    restart_command="REMOTE_PORT=$(rcodex_format_shell_arg "$REMOTE_PORT") $restart_command"
  fi

  cat <<EOF
port_is_open() {
  (exec 3<>"/dev/tcp/127.0.0.1/\$port") >/dev/null 2>&1
}

if [[ ! -x "\$HOME/.codex/bin/render-config" ]]; then
  echo "rcodex-sync: remote render-config is missing or not executable" >&2
  exit 1
fi

"\$HOME/.codex/bin/render-config"

if port_is_open; then
  echo $(rcodex_shell_quote "rcodex-sync: remote codex app-server is running; restart it with: $restart_command") >&2
fi
EOF
}

sync_codex() {
  local script status

  stage_codex_config

  script=$(remote_prepare_script)
  rcodex_run_remote "rcodex-sync" "prepare remote codex directory" "$host" "$script" || exit 1

  echo "rcodex-sync: syncing staged .codex to $host:~/.codex" >&2

  set +e
  rsync -azL --rsync-path="PATH=\"\$HOME/.local/bin:\$HOME/bin:\$PATH\" rsync" "$stage_home/.codex/" "$host:.codex/"
  status=$?
  set -e

  if ((status != 0)); then
    die "failed to rsync staged .codex to $host:~/.codex (rsync status $status)"
  fi

  script=$(remote_render_script)
  rcodex_run_remote "rcodex-sync" "render remote codex config" "$host" "$script" print || exit 1

  echo "rcodex-sync: synced $host" >&2
}

if [[ ${1-} == "-h" || ${1-} == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -eq 1 ]] || {
  usage >&2
  die "host is required"
}

if [[ $1 == -* ]]; then
  usage >&2
  die "host is required"
fi

host=$1
repo_dir="$(cd -- "$script_dir/../../../.." && pwd)"
config_dirs=(common)
stage_home=

cleanup() {
  if [[ $stage_home != "" ]]; then
    rm -rf "$stage_home"
  fi
}

trap cleanup EXIT

plat="$(uname)"
if [[ $plat == "Linux" ]]; then
  config_dirs+=(linux)
elif [[ $plat == "Darwin" ]]; then
  config_dirs+=(macos)
fi

if [[ -d $repo_dir/config/openai ]]; then
  config_dirs+=(openai)
fi

if ! command -v rsync >/dev/null 2>&1; then
  die "local rsync binary not found"
fi

if ! command -v stow >/dev/null 2>&1; then
  die "local stow binary not found"
fi

sync_codex
