#!/bin/bash

set -eu -o pipefail

if [ $# -eq 0 ] || { [[ $1 != "system" && $1 != "latest" ]] && [[ ! $1 =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; }; then
  echo "Usage: goswitch <1.2.3|latest|system>"
  exit 1
fi

version="$1"

toolchain_dir="$XDG_TOOLCHAINS_HOME/go"
current_dir="$toolchain_dir/current"

if [[ $version == "system" ]]; then
  rm -f "$current_dir"
  echo "$toolchain_dir/current" was unlinked
  exit 0
fi

if [[ $version == "latest" ]]; then
  version="$(curl -fsSL "https://go.dev/VERSION?m=text" |
    awk 'NR == 1 {
      version = $0
      sub(/^go/, "", version)
    } END { print version }')"
  if [[ ! $version =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Could not resolve latest stable Go version." >&2
    exit 1
  fi
fi

install_dir="$toolchain_dir/versions/$version"

plat="$(uname -s | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"

case "$arch" in
"x86_64")
  arch="amd64"
  ;;
esac

if [[ ! -d $install_dir ]]; then
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  pushd "$tmpdir" >/dev/null

  curl -L "https://go.dev/dl/go${version}.${plat}-${arch}.tar.gz" -o go.tar.gz
  mkdir -p "$install_dir"
  tar -xzf go.tar.gz -C "$install_dir" --strip-components 1

  popd >/dev/null
fi

rm -f "$current_dir"
ln -s "$install_dir" "$current_dir"
echo "$toolchain_dir/current" now points to "$version"
