#!/bin/bash

set -eu -o pipefail

if [ $# -eq 0 ] || { [[ $1 != "system" && $1 != "latest" ]] && [[ ! $1 =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; }; then
  echo "Usage: goswitch <1.2.3|latest|system>"
  exit 1
fi

version="$1"

toolchain_dir="$XDG_TOOLCHAINS_HOME/go"
current_dir="$toolchain_dir/current"

if [[ $version == "system" ]]; then
  rm -f "$current_dir"
  echo "$toolchain_dir/current" was unlinked
  exit 0
fi

if [[ $version == "latest" ]]; then
  version="$(curl -fsSL "https://go.dev/VERSION?m=text" |
    awk 'NR == 1 {
      version = $0
      sub(/^go/, "", version)
    } END { print version }')"
  if [[ ! $version =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Could not resolve latest stable Go version." >&2
    exit 1
  fi
fi

versions_dir="$toolchain_dir/versions"
install_dir="$versions_dir/$version"

plat="$(uname -s | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"

case "$arch" in
"x86_64")
  arch="amd64"
  ;;
esac

if [[ -d $install_dir && ! -x $install_dir/bin/go ]]; then
  echo "Existing Go install is incomplete: $install_dir" >&2
  echo "Remove it and rerun goswitch." >&2
  exit 1
fi

if [[ ! -d $install_dir ]]; then
  mkdir -p "$versions_dir"
  tmpdir="$(mktemp -d "$versions_dir/.${version}.XXXXXX")"
  staging_dir="$tmpdir/stage"
  trap 'rm -rf "$tmpdir"' EXIT

  mkdir "$staging_dir"

  curl -fL "https://go.dev/dl/go${version}.${plat}-${arch}.tar.gz" -o "$tmpdir/go.tar.gz"
  tar -xzf "$tmpdir/go.tar.gz" -C "$staging_dir" --strip-components 1

  if [[ ! -x $staging_dir/bin/go ]]; then
    echo "Downloaded Go archive did not contain bin/go." >&2
    exit 1
  fi

  mv "$staging_dir" "$install_dir"
fi

rm -f "$current_dir"
ln -s "$install_dir" "$current_dir"
echo "$toolchain_dir/current" now points to "$version"
