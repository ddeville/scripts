#!/bin/bash

set -eu -o pipefail

is_linked_worktree() {
  local repo_root git_dir common_dir

  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -z "$repo_root" ]; then
    return 1
  fi

  git_dir="$(git -C "$repo_root" rev-parse --path-format=absolute --git-dir)"
  common_dir="$(git -C "$repo_root" rev-parse --path-format=absolute --git-common-dir)"

  [ "$git_dir" != "$common_dir" ]
}

if is_linked_worktree; then
  gh pr merge --admin --squash

  printf 'Run cwrm to remove this worktree and branch? [y/N] '
  read -r answer

  case "$answer" in
  [yY] | [yY][eE][sS])
    cwrm
    ;;
  *)
    echo "Skipped cwrm."
    ;;
  esac
else
  gh pr merge --admin --delete-branch --squash
fi
