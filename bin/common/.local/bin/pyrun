#!/bin/bash

set -eu -o pipefail

if [ $# -eq 0 ]; then
  echo "Usage: pyrun <command> [args...]"
  exit 1
fi

if [ -n "${VIRTUAL_ENV-}" ] && [ -d "$VIRTUAL_ENV/bin" ]; then
  export PATH="$VIRTUAL_ENV/bin:$PATH"
  exec "$@"
fi

global_dir="$XDG_TOOLCHAINS_HOME/python/global"
global_venv="$global_dir/venv"
requirements_file="$global_dir/requirements.txt"

if [ -d "$global_venv/bin" ]; then
  export VIRTUAL_ENV="$global_venv"
  export PATH="$global_venv/bin:$PATH"
  unset PYTHONHOME
  exec "$@"
fi

cmd=(uv run)
if [ -f "$requirements_file" ]; then
  cmd+=(--with-requirements "$requirements_file")
fi
cmd+=(-- "$@")

exec "${cmd[@]}"
