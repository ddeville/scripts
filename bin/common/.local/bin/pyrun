#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$script_dir/../lib/python-toolchain.bash"
export bad="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

if [ $# -eq 0 ]; then
  echo "Usage: pyrun <command> [args...]"
  exit 1
fi

if [ -n "${VIRTUAL_ENV-}" ] && [ -d "$VIRTUAL_ENV/bin" ]; then
  export PATH="$VIRTUAL_ENV/bin:$PATH"
  exec "$@"
fi

if [ -d "$PYTHON_TOOLCHAIN_GLOBAL_VENV/bin" ]; then
  export VIRTUAL_ENV="$PYTHON_TOOLCHAIN_GLOBAL_VENV"
  export PATH="$PYTHON_TOOLCHAIN_GLOBAL_VENV/bin:$PATH"
  unset PYTHONHOME
  exec "$@"
fi

cmd=(uv run)
if [ -f "$PYTHON_TOOLCHAIN_REQUIREMENTS_FILE" ]; then
  cmd+=(--with-requirements "$PYTHON_TOOLCHAIN_REQUIREMENTS_FILE")
fi
cmd+=(-- "$@")

exec "${cmd[@]}"
