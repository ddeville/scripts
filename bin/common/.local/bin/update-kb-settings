#!/bin/bash

set -eu -o pipefail

set_xkb_repeat_rate() {
  local DELAY_MS=$1
  local RATE_PER_SECOND=$2

  xset r rate "$DELAY_MS" "$RATE_PER_SECOND"

  # xset only updates the core keyboard; input-remapper's forwarded keyboard
  # can keep its own stale XKB repeat rate.
  /usr/bin/python3 - "$DELAY_MS" "$RATE_PER_SECOND" <<'PY' || true
import ctypes, re, subprocess, sys

def keyboard_device_ids():
    for line in subprocess.check_output(["xinput", "list", "--short"], text=True).splitlines():
        if "keyboard" in line.lower():
          if match := re.search(r"\bid=(\d+)\b", line):
              yield int(match.group(1))

delay_ms = int(sys.argv[1])
interval_ms = max(1, round(1000 / int(sys.argv[2])))

x11 = ctypes.CDLL("libX11.so.6")
x11.XOpenDisplay.argtypes = [ctypes.c_char_p]
x11.XOpenDisplay.restype = ctypes.c_void_p
x11.XCloseDisplay.argtypes = [ctypes.c_void_p]
x11.XFlush.argtypes = [ctypes.c_void_p]
x11.XkbSetAutoRepeatRate.argtypes = [ctypes.c_void_p, ctypes.c_uint, ctypes.c_uint, ctypes.c_uint]

if display := x11.XOpenDisplay(None):
  try:
      for device_id in sorted(set(keyboard_device_ids())):
          x11.XkbSetAutoRepeatRate(display, device_id, delay_ms, interval_ms)
      x11.XFlush(display)
  finally:
      x11.XCloseDisplay(display)
else:
    sys.exit(1)
PY
}

if [[ $(uname) == Linux ]]; then
  if [ -x /usr/bin/python3 ] && [ -x /usr/bin/input-remapper-control ]; then
    # Refresh input-remapper before applying settings to the forwarded touchpad device.
    /usr/bin/python3 /usr/bin/input-remapper-control --command stop-all || true
    /usr/bin/python3 /usr/bin/input-remapper-control --command autoload || true
    sleep 1.5
  fi

  if [ -f /etc/X11/xinit/.Xmodmap ]; then
    xmodmap /etc/X11/xinit/.Xmodmap
  fi
  if [ -e "$HOME/.Xmodmap" ]; then
    xmodmap "$HOME/.Xmodmap"
  fi

  if [[ $(hostname) == "framework" ]]; then
    # Decimal vendor/product IDs from xinput's "Device Product ID" property: PIXA3854:00 093A:0274
    FRAMEWORK_TOUCHPAD_PRODUCT_ID="2362, 628"

    while read -r TOUCHPAD_ID; do
      if [ -n "$TOUCHPAD_ID" ]; then
        # Natural scrolling
        if xinput list-props "$TOUCHPAD_ID" | grep -q "libinput Natural Scrolling Enabled"; then
          xinput set-prop "$TOUCHPAD_ID" "libinput Natural Scrolling Enabled" 1
        fi
        # Make any physical touchpad click emit a left click.
        xinput set-button-map "$TOUCHPAD_ID" 1 1 1 4 5 6 7
      fi
    done < <(
      xinput list --short |
        awk '/slave[[:space:]]+pointer/ && match($0, /id=[0-9]+/) {
              print substr($0, RSTART + 3, RLENGTH - 3)
            }' |
        while read -r DEVICE_ID; do
          if xinput list-props "$DEVICE_ID" | grep -q "Device Product ID.*$FRAMEWORK_TOUCHPAD_PRODUCT_ID"; then
            echo "$DEVICE_ID"
          fi
        done
    )
  fi

  if command -v xdotool >/dev/null && xset q | grep -q "Caps Lock: *on"; then
    xdotool key Caps_Lock || true
  fi
  xsetroot -cursor_name left_ptr
  set_xkb_repeat_rate 180 50

elif [[ $(uname) == Darwin ]]; then
  # Remap Caps Lock as Control (see https://developer.apple.com/library/archive/technotes/tn2450/_index.html)
  modifiermapping="$(
    hidutil list --ndjson | jq -r '
      select(
        ."Built-In" == true and
        .PrimaryUsagePage == 1 and
        .PrimaryUsage == 6
      )
      | "com.apple.keyboard.modifiermapping.\(.VendorID)-\(.ProductID)-0"
    ' | head -n1
  )"
  if [[ -n $modifiermapping ]]; then
    hidutil property --set '{
      "UserKeyMapping": [{
        "HIDKeyboardModifierMappingSrc": 0x700000039,
        "HIDKeyboardModifierMappingDst": 0x7000000E0,
      }]
    }'
    defaults -currentHost write NSGlobalDomain "$modifiermapping" -array '{
      HIDKeyboardModifierMappingSrc = 30064771129;
      HIDKeyboardModifierMappingDst = 30064771296;
    }'
  else
    echo "Unable to find a built-in keyboard for persistent modifier mapping." >&2
  fi
else
  echo "Unsupported platform: $(uname)" >&2
  exit 1
fi
