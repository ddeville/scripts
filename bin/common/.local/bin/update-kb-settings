#!/bin/bash

set -eu -o pipefail

if [[ $(uname) == Linux ]]; then
  xset r rate 180 50
  xsetroot -cursor_name left_ptr

  if [ -f /etc/X11/xinit/.Xmodmap ]; then
    xmodmap /etc/X11/xinit/.Xmodmap
  fi
  if [ -e "$HOME/.Xmodmap" ]; then
    xmodmap "$HOME/.Xmodmap"
  fi

  # If not running on my main desktop that has a programmed keychron keyboard, let's tweak
  # a few keys.
  if [[ $(hostname) == "framework" ]]; then
    # Clear all the modifiers that we're going to edit
    xmodmap -e "clear lock"
    xmodmap -e "clear control"
    xmodmap -e "clear mod1"
    xmodmap -e "clear mod4"

    # Set Caps Lock to Left Control
    xmodmap -e "keycode 66 = Control_L"
    # Set Left Alt to Left Control
    xmodmap -e "keycode 64 = Control_L"
    # Set Right Alt to Left Super
    xmodmap -e "keycode 108 = Super_L"
    # Set Left Control to Left Super
    xmodmap -e "keycode 37 = Super_L"
    # Set Left Super to Left Alt
    xmodmap -e "keycode 133 = Alt_L"

    # Restore the modifiers
    xmodmap -e "add control = Control_L Control_R"
    xmodmap -e "add mod1 = Alt_L"
    xmodmap -e "add mod4 = Super_L Super_R"

    TOUCHPAD="PIXA3854:00 093A:0274 Touchpad"

    # Natural scrolling
    xinput set-prop "$TOUCHPAD" "libinput Natural Scrolling Enabled" 1

    # Make any physical touchpad click emit a left click.
    xinput set-button-map "$TOUCHPAD" 1 1 1 4 5 6 7
  fi
elif [[ $(uname) == Darwin ]]; then
  # Remap Caps Lock as Control (see https://developer.apple.com/library/archive/technotes/tn2450/_index.html)
  modifiermapping="$(
    hidutil list --ndjson | jq -r '
      select(
        ."Built-In" == true and
        .PrimaryUsagePage == 1 and
        .PrimaryUsage == 6
      )
      | "com.apple.keyboard.modifiermapping.\(.VendorID)-\(.ProductID)-0"
    ' | head -n1
  )"
  if [[ -n $modifiermapping ]]; then
    hidutil property --set '{
      "UserKeyMapping": [{
        "HIDKeyboardModifierMappingSrc": 0x700000039,
        "HIDKeyboardModifierMappingDst": 0x7000000E0,
      }]
    }'
    defaults -currentHost write NSGlobalDomain "$modifiermapping" -array '{
      HIDKeyboardModifierMappingSrc = 30064771129;
      HIDKeyboardModifierMappingDst = 30064771296;
    }'
  else
    echo "Unable to find a built-in keyboard for persistent modifier mapping." >&2
  fi
else
  echo "Unsupported platform: $(uname)" >&2
  exit 1
fi
