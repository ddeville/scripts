#!/bin/bash

set -eu -o pipefail

usage() {
  cat <<'EOF'
Usage: provision-devbox <host>

Provision a devbox over SSH.
EOF
}

die() {
  echo "provision-devbox: $*" >&2
  exit 1
}

start_control_master() {
  local output status

  control_path=${TMPDIR:-/tmp}/provision-devbox-ssh-control.$$

  set +e
  output=$(ssh \
    -MNf \
    -S "$control_path" \
    -o ClearAllForwardings=yes \
    "$host" 2>&1)
  status=$?
  set -e

  if ((status != 0)); then
    output=${output//$'\n'/ }
    die "failed to start ssh control master (ssh status $status): ${output:-<empty>}"
  fi
}

ssh_remote() {
  ssh -F none -S "$control_path" "$host" "$@"
}

install_repo_snapshot() {
  local remote_script repo_name repo_url pack_tmp

  repo_name=$1
  repo_url=$2

  echo "provision-devbox: installing remote ~/$repo_name" >&2
  remote_script=$(
    printf '%s\n\n' 'set -eu'
    printf "repo_name='%s'\n\n" "$repo_name"
    cat <<'EOF'
if [ -e "$HOME/$repo_name" ]; then
  rm -rf "$HOME/$repo_name"
fi

tmp_tar=$(mktemp "${TMPDIR:-/tmp}/${repo_name}.XXXXXX.tar.gz")
cleanup() {
  rm -f "$tmp_tar"
}
trap cleanup EXIT

cat >"$tmp_tar"
tar -xzf "$tmp_tar" -C "$HOME"
EOF
  )

  pack_tmp=$(mktemp -d)
  git clone --depth 1 "$repo_url" "$pack_tmp/$repo_name"
  rm -rf "$pack_tmp/$repo_name/.git"
  rm -rf "$pack_tmp/$repo_name/.github"

  COPYFILE_DISABLE=1 tar -cz --no-xattrs --exclude .DS_Store -f - -C "$pack_tmp" "$repo_name" |
    ssh_remote "$remote_script"

  rm -rf "$pack_tmp"
}

run_devbox_installer() {
  echo "provision-devbox: running remote devbox installer" >&2

  ssh_remote 'exec ~/scripts/install/devbox/install.sh'
}

cleanup() {
  if [ -n "$control_path" ]; then
    ssh -F none -S "$control_path" -O exit "$host" >/dev/null 2>&1 || true
    rm -f "$control_path"
  fi
}

if [ "${1-}" = "-h" ] || [ "${1-}" = "--help" ]; then
  usage
  exit 0
fi

[ $# -eq 1 ] || {
  usage >&2
  die "host is required"
}

host=$1
control_path=

trap cleanup EXIT
trap 'trap - EXIT; cleanup; exit 130' INT
trap 'trap - EXIT; cleanup; exit 143' TERM

start_control_master

install_repo_snapshot scripts https://github.com/ddeville/scripts.git
if [ -d "$HOME/scripts/config/openai" ]; then
  install_repo_snapshot scripts-openai https://github.com/ddeville/scripts-openai.git
fi

run_devbox_installer
