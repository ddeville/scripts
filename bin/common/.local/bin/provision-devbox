#!/bin/bash

set -eu -o pipefail

usage() {
  cat <<'EOF'
Usage: provision-devbox <host>

Provision a devbox over SSH.

Environment:
  PROVISION_DEVBOX_FULL_INSTALL=1  Run install/devbox/install.sh instead of install_minimal.sh.
  PROVISION_DEVBOX_SKIP_INSTALL=1  Skip running the remote devbox installer.
EOF
}

die() {
  echo "provision-devbox: $*" >&2
  exit 1
}

start_control_master() {
  local output status

  control_path=${TMPDIR:-/tmp}/provision-devbox-ssh-control.$$

  set +e
  output=$(ssh \
    -MNf \
    -S "$control_path" \
    -o ClearAllForwardings=yes \
    "$host" 2>&1)
  status=$?
  set -e

  if ((status != 0)); then
    output=${output//$'\n'/ }
    die "failed to start ssh control master (ssh status $status): ${output:-<empty>}"
  fi
}

ssh_remote() {
  ssh -F none -S "$control_path" "$host" "$@"
}

install_repo_snapshot() {
  local remote_script repo_name repo_path pack_tmp staged_repo

  repo_name=$1
  repo_path=$2

  if ! git -C "$repo_path" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    die "local path is not inside a git repository: $repo_path"
  fi

  echo "provision-devbox: installing remote ~/$repo_name from $repo_path" >&2
  remote_script=$(
    printf '%s\n\n' 'set -eu'
    printf "repo_name='%s'\n\n" "$repo_name"
    cat <<'EOF'
if [ -e "$HOME/$repo_name" ]; then
  rm -rf "$HOME/$repo_name"
fi

tmp_tar=$(mktemp "${TMPDIR:-/tmp}/${repo_name}.XXXXXX.tar.gz")
cleanup() {
  rm -f "$tmp_tar"
}
trap cleanup EXIT

cat >"$tmp_tar"
tar -xzf "$tmp_tar" -C "$HOME"
EOF
  )

  pack_tmp=$(mktemp -d)
  staged_repo="$pack_tmp/$repo_name"
  mkdir "$staged_repo"

  git -C "$repo_path" ls-files -z |
    while IFS= read -r -d '' path; do
      if [ -e "$repo_path/$path" ] || [ -L "$repo_path/$path" ]; then
        printf '%s\0' "$path"
      fi
    done |
    rsync -a --from0 --files-from=- "$repo_path"/ "$staged_repo"/

  git -C "$staged_repo" init -q
  git -C "$staged_repo" add -A
  git -C "$staged_repo" \
    -c user.name=provision-devbox \
    -c user.email=provision-devbox@localhost \
    -c commit.gpgsign=false \
    commit -qm "Provision snapshot"

  COPYFILE_DISABLE=1 tar -cz --no-xattrs -f - -C "$pack_tmp" "$repo_name" |
    ssh_remote "$remote_script"

  rm -rf "$pack_tmp"
}

run_devbox_installer() {
  echo "provision-devbox: running remote devbox installer ($devbox_installer)" >&2

  ssh_remote "exec ~/scripts/install/devbox/$devbox_installer"
}

cleanup() {
  if [ -n "$control_path" ]; then
    ssh -F none -S "$control_path" -O exit "$host" >/dev/null 2>&1 || true
    rm -f "$control_path"
  fi
}

if [ "${1-}" = "-h" ] || [ "${1-}" = "--help" ]; then
  usage
  exit 0
fi

[ $# -eq 1 ] || {
  usage >&2
  die "host is required"
}

host=$1
control_path=
[ -n "${PROVISION_DEVBOX_FULL_INSTALL:-}" ] && devbox_installer=install.sh || devbox_installer=install_minimal.sh

trap cleanup EXIT
trap 'trap - EXIT; cleanup; exit 130' INT
trap 'trap - EXIT; cleanup; exit 143' TERM

start_control_master

install_repo_snapshot scripts "$HOME/scripts"
if [ -d "$HOME/scripts/config/openai" ]; then
  install_repo_snapshot scripts-openai "$HOME/scripts-openai"
fi

if [ -n "${PROVISION_DEVBOX_SKIP_INSTALL:-}" ]; then
  echo "provision-devbox: skipping remote devbox installer" >&2
else
  run_devbox_installer
fi
