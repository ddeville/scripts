#!/bin/bash

set -eu -o pipefail

remote_port=17338

local_port_range_start=17338
local_port_range_end=17538

usage() {
  cat <<'EOF'
Usage: rcodex <host> [codex-args...]

Connect a local Codex TUI to a Codex app-server reachable only over SSH.

Examples:
  rcodex host --cd src/project
  rcodex host --model gpt-5.2
EOF
}

die() {
  echo "rcodex: $*" >&2
  exit 1
}

shell_quote() {
  local value quoted
  value=$1
  quoted=${value//\'/\'\\\'\'}
  printf "'%s'" "$quoted"
}

port_is_open() {
  local port=$1
  (exec 3<>"/dev/tcp/127.0.0.1/$port") >/dev/null 2>&1
}

choose_local_port() {
  local port

  for ((port = local_port_range_start; port <= local_port_range_end; port++)); do
    if ! port_is_open "$port"; then
      printf '%s\n' "$port"
      return 0
    fi
  done

  die "no free local port found in $local_port_range_start-$local_port_range_end"
}

wait_for_tunnel() {
  local local_port wait_seconds attempts i
  local_port=$1
  wait_seconds=20
  attempts=$((wait_seconds * 5))

  for ((i = 0; i < attempts; i++)); do
    if port_is_open "$local_port"; then
      return 0
    fi

    if ! kill -0 "$ssh_pid" 2>/dev/null; then
      echo "rcodex: ssh exited before Codex was reachable" >&2
      wait "$ssh_pid" || true
      return 1
    fi

    sleep 0.2
  done

  echo "rcodex: timed out waiting for ws://127.0.0.1:$local_port" >&2
  return 1
}

remote_ensure_script() {
  local login_hint
  login_hint="rcodex: run: ssh $(shell_quote "$host") codex login"

  cat <<EOF
set -eu

port=$remote_port

port_is_open() {
  (exec 3<>"/dev/tcp/127.0.0.1/\$port") >/dev/null 2>&1
}

if ! command -v codex >/dev/null 2>&1; then
  echo "rcodex: remote codex binary not found" >&2
  exit 127
fi

if port_is_open; then
  exit 0
fi

if ! codex login status >/dev/null 2>&1; then
  echo "rcodex: remote Codex login status failed" >&2
  echo $(shell_quote "$login_hint") >&2
  exit 1
fi

cd "\$HOME"
log_dir="\${XDG_STATE_HOME:-\$HOME/.local/state}/rcodex"
mkdir -p "\$log_dir"
log_file="\$log_dir/app-server-\$port.log"

nohup codex app-server --listen "ws://127.0.0.1:\$port" >"\$log_file" 2>&1 &
server_pid=\$!

for _ in {1..100}; do
  if port_is_open; then
    exit 0
  fi

  if ! kill -0 "\$server_pid" 2>/dev/null; then
    echo "rcodex: remote Codex app-server exited during startup" >&2
    echo "rcodex: log: \$log_file" >&2
    exit 1
  fi

  sleep 0.2
done

echo "rcodex: timed out starting remote Codex app-server" >&2
echo "rcodex: log: \$log_file" >&2
exit 1
EOF
}

if [[ ${1-} == "-h" || ${1-} == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -gt 0 ]] || {
  usage >&2
  die "host is required"
}

if [[ $1 == -* ]]; then
  usage >&2
  die "host is required before codex args"
fi

host=$1
shift
codex_args=("$@")

local_port=$(choose_local_port)

if ! command -v codex >/dev/null 2>&1; then
  die "local codex binary not found"
fi

echo "rcodex: ensuring Codex is running on $host:$remote_port" >&2
script=$(remote_ensure_script)
# shellcheck disable=SC2029
ssh "$host" "bash -lc $(shell_quote "$script")"

ssh_cmd=(
  ssh
  -o ExitOnForwardFailure=yes
  -L "127.0.0.1:$local_port:127.0.0.1:$remote_port"
  "$host"
)

ssh_cmd+=(-N)
echo "rcodex: connecting to Codex on $host:$remote_port via local port $local_port" >&2

"${ssh_cmd[@]}" &
ssh_pid=$!

# shellcheck disable=SC2329
cleanup() {
  if kill -0 "$ssh_pid" 2>/dev/null; then
    kill "$ssh_pid" 2>/dev/null || true
    wait "$ssh_pid" 2>/dev/null || true
  fi
}

trap cleanup EXIT
trap 'trap - EXIT; cleanup; exit 130' INT
trap 'trap - EXIT; cleanup; exit 143' TERM

wait_for_tunnel "$local_port" || exit 1

client_cmd=(codex --remote "ws://127.0.0.1:$local_port" "${codex_args[@]}")

set +e
"${client_cmd[@]}"
client_status=$?
set -e

exit "$client_status"
