#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" && pwd)"
source "$script_dir/../lib/rcodex.bash"

usage() {
  cat <<'EOF'
Usage: rcodex <host> [codex-args...]

Connect a local Codex TUI to a Codex app-server reachable only over SSH.

Environment:
  REMOTE_PORT  Remote app-server port; default: 17338

Examples:
  rcodex host --cd src/project
  REMOTE_PORT=17339 rcodex host
  rcodex host --model gpt-5.5
EOF
}

die() {
  echo "rcodex: $*" >&2
  exit 1
}

start_tunnel() {
  local last_output last_status output port status

  for ((port = RCODEX_REMOTE_PORT; port < RCODEX_REMOTE_PORT + 200; port++)); do
    set +e
    output=$(ssh \
      -F none \
      -S "$control_path" \
      -O forward \
      -o ExitOnForwardFailure=yes \
      -L "127.0.0.1:$port:127.0.0.1:$RCODEX_REMOTE_PORT" \
      "$host" 2>&1)
    status=$?
    set -e

    if ((status == 0)); then
      local_port=$port
      echo "rcodex: connecting to codex on $host:$RCODEX_REMOTE_PORT via local port $local_port" >&2
      return 0
    fi

    last_output=$output
    last_status=$status
  done

  last_output=${last_output//$'\n'/ }
  echo "rcodex: failed to allocate local tunnel port in range $RCODEX_REMOTE_PORT-$((RCODEX_REMOTE_PORT + 199)) (last ssh status $last_status)" >&2
  echo "rcodex: output: ${last_output:-<empty>}" >&2
  return 1
}

print_resume_command() {
  local resume_args=()
  local arg
  local command_color=""
  local reset_color=""

  resume_args=(resume --last "$@")
  for arg in "$@"; do
    if [[ $arg == "resume" ]]; then
      resume_args=("$@")
      break
    fi
  done

  if [[ -t 2 && ${NO_COLOR-} == "" ]]; then
    command_color=$'\033[36m'
    reset_color=$'\033[0m'
  fi

  echo "rcodex: disconnected" >&2
  printf 'rcodex: to resume with the same launch args, run: %s' "$command_color" >&2

  if [[ ${REMOTE_PORT-} != "" ]]; then
    printf 'REMOTE_PORT=%s ' "$(rcodex_format_shell_arg "$REMOTE_PORT")" >&2
  fi

  printf 'rcodex' >&2
  rcodex_print_command_arg "$host" >&2
  for arg in "${resume_args[@]}"; do
    rcodex_print_command_arg "$arg" >&2
  done
  printf '%s\n' "$reset_color" >&2
}

remote_ensure_script() {
  local login_hint
  login_hint="rcodex: run: ssh $(rcodex_shell_quote "$host") codex login"

  cat <<EOF
port_is_open() {
  (exec 3<>"/dev/tcp/127.0.0.1/\$port") >/dev/null 2>&1
}

if ! command -v codex >/dev/null 2>&1; then
  echo "rcodex: remote codex binary not found" >&2
  exit 127
fi

cd "\$HOME"

if port_is_open; then
  exit 0
fi

if ! codex login status >/dev/null 2>&1; then
  echo "rcodex: remote codex login status failed" >&2
  echo $(rcodex_shell_quote "$login_hint") >&2
  exit 1
fi

nohup codex app-server --listen "ws://127.0.0.1:\$port" >"\$log_file" 2>&1 &
server_pid=\$!
printf '%s\n' "\$server_pid" >"\$pid_file"

for attempt in {1..100}; do
  if port_is_open; then
    exit 0
  fi

  if ! kill -0 "\$server_pid" 2>/dev/null; then
    rm -f "\$pid_file"
    echo "rcodex: remote codex app-server exited during startup" >&2
    echo "rcodex: log: \$log_file" >&2
    exit 1
  fi

  sleep 0.2
done

echo "rcodex: timed out starting remote codex app-server" >&2
echo "rcodex: log: \$log_file" >&2
exit 1
EOF
}

if [[ ${1-} == "-h" || ${1-} == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -gt 0 ]] || {
  usage >&2
  die "host is required"
}

if [[ $1 == -* ]]; then
  usage >&2
  die "host is required before codex args"
fi

host=$1
shift
control_path=

if ! command -v codex >/dev/null 2>&1; then
  die "local codex binary not found"
fi

# shellcheck disable=SC2317,SC2329
cleanup() {
  if [[ $control_path != "" ]]; then
    rcodex_stop_control_master "$host" "$control_path"
    rm -f "$control_path"
  fi
}

trap cleanup EXIT
trap 'trap - EXIT; cleanup; exit 130' INT
trap 'trap - EXIT; cleanup; exit 143' TERM

control_path=$(rcodex_make_control_path)
rcodex_start_control_master "$host" "$control_path" || exit 1

echo "rcodex: ensuring codex is running on $host:$RCODEX_REMOTE_PORT" >&2
script=$(remote_ensure_script)
rcodex_run_remote "ensure remote codex app-server" "$host" "$script" "$control_path" || exit 1

start_tunnel || exit 1

set +e
codex --remote "ws://127.0.0.1:$local_port" "$@"
client_status=$?
set -e

print_resume_command "$@"

exit "$client_status"
