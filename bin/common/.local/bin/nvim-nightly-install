#!/bin/bash

set -eu -o pipefail

NVIM_INSTALL_PATH="/opt/nvim"

function _copy_dir_contents {
  local source_dir="$1"
  local target_dir="$2"

  tar -C "$source_dir" -cf - . | tar -C "$target_dir" -xf -
}

function _move_dir_contents {
  local entry
  local source_dir="$1"
  local target_dir="$2"
  local status=0

  shopt -s dotglob nullglob
  for entry in "$source_dir"/*; do
    if ! mv "$entry" "$target_dir"/; then
      status=1
      break
    fi
  done
  shopt -u dotglob nullglob

  return "$status"
}

function _replace_nvim_install {
  local backup_dir entry source_dir stage_dir

  source_dir="$1"
  stage_dir="$(mktemp -d "$NVIM_INSTALL_PATH/.stage.XXXXXX")"
  backup_dir="$(mktemp -d "$NVIM_INSTALL_PATH/.backup.XXXXXX")"

  if ! _copy_dir_contents "$source_dir" "$stage_dir"; then
    rm -rf "$stage_dir" "$backup_dir"
    echo "Failed to stage Neovim install." >&2
    return 1
  fi

  if [ ! -x "$stage_dir/bin/nvim" ]; then
    rm -rf "$stage_dir" "$backup_dir"
    echo "Staged Neovim install does not contain bin/nvim." >&2
    return 1
  fi

  shopt -s dotglob nullglob
  for entry in "$NVIM_INSTALL_PATH"/*; do
    case "$entry" in
    "$stage_dir" | "$backup_dir")
      continue
      ;;
    esac

    if ! mv "$entry" "$backup_dir"/; then
      shopt -u dotglob nullglob
      _move_dir_contents "$backup_dir" "$NVIM_INSTALL_PATH"
      rm -rf "$stage_dir"
      echo "Failed to back up existing Neovim install. Restored any moved files." >&2
      return 1
    fi
  done
  shopt -u dotglob nullglob

  if ! _move_dir_contents "$stage_dir" "$NVIM_INSTALL_PATH"; then
    echo "Failed to move staged Neovim install into place. Restoring previous install." >&2
    shopt -s dotglob nullglob
    for entry in "$NVIM_INSTALL_PATH"/*; do
      case "$entry" in
      "$stage_dir" | "$backup_dir")
        continue
        ;;
      esac

      rm -rf "$entry"
    done
    shopt -u dotglob nullglob

    _move_dir_contents "$backup_dir" "$NVIM_INSTALL_PATH"
    rm -rf "$stage_dir" "$backup_dir"
    return 1
  fi

  rm -rf "$stage_dir" "$backup_dir"
}

function _setup {
  # Create install path if needed
  if [ ! -d "$NVIM_INSTALL_PATH" ]; then
    echo "Creating install folder"
    sudo mkdir -p "$NVIM_INSTALL_PATH"
    sudo chown "$USER" "$NVIM_INSTALL_PATH"
  fi

  # Make sure it's a folder with the right permissions
  if [ ! -d "$NVIM_INSTALL_PATH" ] || [ -f "$NVIM_INSTALL_PATH" ] || [ ! -O "$NVIM_INSTALL_PATH" ]; then
    echo "Make sure that $NVIM_INSTALL_PATH is a directory and is owned by $USER"
    exit 1
  fi
}

function _nvim_nightly_prebuilt {
  _setup

  # Get the download URL for the nightly package for the current platform
  platform="$(uname)"
  arch="$(uname -m)"

  case "$platform" in
  Darwin)
    filename="nvim-macos-${arch}.tar.gz"
    foldername="nvim-macos-${arch}"
    ;;
  Linux)
    case "$arch" in
    x86_64)
      filename="nvim-linux-x86_64.tar.gz"
      foldername="nvim-linux-x86_64"
      ;;
    arm64 | aarch64)
      filename="nvim-linux-arm64.tar.gz"
      foldername="nvim-linux-arm64"
      ;;
    *)
      echo "Unsupported Linux architecture: $arch"
      exit 1
      ;;
    esac
    ;;
  *)
    echo "Unsupported platform: $platform"
    exit 1
    ;;
  esac
  url="https://github.com/neovim/neovim/releases/download/nightly/$filename"

  # Download the archive to a temp directory
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "$tmp_dir"' EXIT
  tmp_path="$tmp_dir/$filename"
  echo "Downloading $url to $tmp_path"
  curl -fL --url "$url" --output "$tmp_path"

  # Extract the archive
  tar xzvf "$tmp_path" -C "$tmp_dir"
  rm -f "$tmp_path"

  # Check whether it is a new version
  new_version="$("$tmp_dir/$foldername/bin/nvim" --version | head -n 1)"
  if [ -f "$NVIM_INSTALL_PATH/bin/nvim" ]; then
    cur_version="$($NVIM_INSTALL_PATH/bin/nvim --version | head -n 1)"

    if [[ $cur_version == "$new_version" ]]; then
      echo "Version $cur_version is already installed"
      exit 0
    fi
  fi

  echo "Installing $new_version"
  _replace_nvim_install "$tmp_dir/$foldername"
}

# Prerequisites:
#   macOS: `brew install ninja libtool automake cmake pkg-config gettext`
#   Arch Linux: `sudo pacman -S base-devel cmake unzip ninja tree-sitter curl`
#   Debian: `sudo apt install ninja-build gettext libtool libtool-bin autoconf automake cmake g++ pkg-config unzip`

function _nvim_nightly_compile {
  _setup

  # Download the archive to a temp directory
  url="https://github.com/neovim/neovim/archive/nightly.tar.gz"
  tmp_dir="$(mktemp -d)"
  trap 'rm -rf "$tmp_dir"' EXIT
  tmp_path="$tmp_dir/neovim-nightly.tar.gz"
  echo "Downloading $url to $tmp_path"
  curl -fL --url "$url" --output "$tmp_path"

  # Extract the archive
  tar xzvf "$tmp_path" -C "$tmp_dir"
  rm -f "$tmp_path"

  # Build
  pushd "$tmp_dir/neovim-nightly" >/dev/null
  echo "Building in $(pwd)"
  make CMAKE_BUILD_TYPE=Release CMAKE_EXTRA_FLAGS="-DCMAKE_INSTALL_PREFIX=$tmp_dir/install"
  make install
  popd >/dev/null

  _replace_nvim_install "$tmp_dir/install"
}

function _nvim_nightly_uninstall {
  sudo rm -rf "$NVIM_INSTALL_PATH"
}

case ${1-none} in
prebuilt)
  _nvim_nightly_prebuilt
  ;;
compile)
  _nvim_nightly_compile
  ;;
uninstall)
  _nvim_nightly_uninstall
  ;;
*)
  echo "Available commands"
  echo "  * prebuilt"
  echo "  * compile"
  echo "  * uninstall"
  exit 1
  ;;
esac
