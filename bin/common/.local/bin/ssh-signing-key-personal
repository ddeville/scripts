#!/bin/bash

set -eu -o pipefail

preferred_key="$HOME/.ssh/id_personal.pub"
allowed_signers="$HOME/.config/git/allowed_signers"
fallback_sock="$HOME/.1password/agent.sock"

if [[ -z ${SSH_AUTH_SOCK-} || ! -S ${SSH_AUTH_SOCK-} || ${SSH_AUTH_SOCK-} == /private/tmp/com.apple.launchd.* ]]; then
  export SSH_AUTH_SOCK="$fallback_sock"
fi

if ! agent_keys=$(ssh-add -L 2>/dev/null); then
  echo "No personal SSH signing keys are available from the active agent." >&2
  exit 1
fi

emit_key() {
  printf 'key::%s\n' "$1"
}

key_token() {
  awk 'NF >= 2 { print $1 " " $2; exit }' "$1"
}

if [[ -r $preferred_key ]]; then
  preferred_pub=$(<"$preferred_key")
  preferred_token=$(key_token "$preferred_key")

  if awk -v token="$preferred_token" '($1 " " $2) == token { found = 1 } END { exit !found }' <<<"$agent_keys"; then
    emit_key "$preferred_pub"
    exit 0
  fi
fi

if [[ -r $allowed_signers ]]; then
  if signing_key=$(
    awk '
      NR == FNR {
        agent[$1 " " $2] = $0
        next
      }
      $1 ~ /^#/ || NF < 3 {
        next
      }
      {
        for (i = 2; i < NF; i++) {
          if ($i ~ /^(ssh-|ecdsa-|sk-ssh-|sk-ecdsa)/) {
            token = $i " " $(i + 1)
            if (token in agent) {
              print agent[token]
              found = 1
              exit
            }
          }
        }
      }
      END {
        exit !found
      }
    ' <(printf '%s\n' "$agent_keys") "$allowed_signers"
  ); then
    emit_key "$signing_key"
    exit 0
  fi

  echo "No personal SSH signing key from the active agent is listed in $allowed_signers." >&2
  exit 1
fi

key_count=$(awk 'NF >= 2 { count++ } END { print count + 0 }' <<<"$agent_keys")
if [[ $key_count -eq 1 ]]; then
  emit_key "$agent_keys"
  exit 0
fi

echo "No unambiguous personal SSH signing key is available from the active agent." >&2
echo "Add the forwarded key to $allowed_signers, or expose only one key in the agent." >&2
exit 1
