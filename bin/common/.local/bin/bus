#!/bin/bash

set -eu -o pipefail

trust_homebrew_brewfile() {
  local brew_command=$1
  local brewfile=$2
  local package package_type
  local -a trusted_formulae=()
  local -a trusted_casks=()

  while read -r package_type package; do
    if [[ $package_type == brew ]]; then
      trusted_formulae+=("$package")
    else
      trusted_casks+=("$package")
    fi
  done < <(
    sed -En 's/^[[:space:]]*(brew|cask) "([^"/]+\/[^"/]+\/[^"/]+)".*/\1 \2/p' "$brewfile" |
      sort -u
  )

  if ((${#trusted_formulae[@]})); then
    "$brew_command" trust --formula "${trusted_formulae[@]}"
  fi
  if ((${#trusted_casks[@]})); then
    "$brew_command" trust --cask "${trusted_casks[@]}"
  fi
}

if [ "$(uname)" = "Darwin" ]; then
  homebrew_dir="$HOME/.config/homebrew"

  brewfile="$(mktemp -d)/Brewfile"
  cat "$homebrew_dir/Brewfile.common" >"$brewfile"

  if [[ -f "$homebrew_dir/Brewfile.openai" ]]; then
    cat "$homebrew_dir/Brewfile.openai" >>"$brewfile"
  elif [[ -f "$homebrew_dir/Brewfile.home" ]]; then
    cat "$homebrew_dir/Brewfile.home" >>"$brewfile"
  fi

  trust_homebrew_brewfile brew "$brewfile"

  brew update

  echo -e "\033[34m==>\033[0m Installing from bundle..."
  brew bundle install --file="$brewfile" --upgrade --force-cleanup

  echo -e "\033[34m==>\033[0m Running brew upgrade..."
  brew upgrade

  echo -e "\033[34m==>\033[0m Running brew cleanup..."
  brew cleanup --prune=3
elif [ "$(uname)" = "Linux" ]; then
  if [ -x /usr/bin/paru ]; then
    pkglist_dir="$HOME/.config/pkglist"

    mapfile -t pkgs < <(
      cat "$pkglist_dir"/{base_packages.txt,aur_packages.txt} 2>/dev/null |
        sed 's/#.*//' |
        awk 'NF' |
        sort -u
    )

    env PATH="$(getconf PATH)" /usr/bin/paru -Syyu --needed -- "${pkgs[@]}"
  elif command -v apt >/dev/null 2>&1; then
    sudo apt update
    sudo apt full-upgrade --option APT::Get::Always-Include-Phased-Updates=true --yes
    sudo apt autoremove

    if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
      linuxbrew() {
        sudo runuser -u linuxbrew -- env HOME=/home/linuxbrew HOMEBREW_REQUIRE_TAP_TRUST=1 /home/linuxbrew/.linuxbrew/bin/brew "$@"
      }

      brewfile="$(mktemp /tmp/bus-brewfile.XXXXXX)"
      cp "$HOME/.config/homebrew/Brewfile.devbox" "$brewfile"
      chmod 0644 "$brewfile"
      trap 'rm -f "$brewfile"' EXIT

      pushd /home/linuxbrew >/dev/null

      trust_homebrew_brewfile linuxbrew "$brewfile"

      linuxbrew update

      echo -e "\033[34m==>\033[0m Installing from bundle..."
      linuxbrew bundle install --file="$brewfile" --upgrade --force-cleanup

      echo -e "\033[34m==>\033[0m Running brew upgrade..."
      linuxbrew upgrade

      echo -e "\033[34m==>\033[0m Running brew cleanup..."
      linuxbrew cleanup --prune=3

      popd >/dev/null
    fi
  else
    echo "No known package manager"
    exit 1
  fi
else
  echo "Unsupported platform: $(uname)"
  exit 1
fi
