#!/bin/bash

set -eu -o pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
lib_dir="$script_dir/../lib/stow-config"

dirs=(common)

# Platform-specific stuff
plat="$(uname)"
if [ "$plat" = "Linux" ]; then
  dirs+=(linux)
elif [ "$plat" = "Darwin" ]; then
  dirs+=(macos)
fi

# OpenAI stuff
if [ -d "$HOME/scripts-openai" ]; then
  dirs+=(openai)
fi

# Don't support running stow if the git repo is dirty (since we're using `--adopt`)
if [ -d "$HOME/scripts/.git" ] && [ -n "$(git -C "$HOME/scripts" status --porcelain)" ]; then
  echo "ERROR: $HOME/scripts is dirty, please commit changes before running stow-config"
  exit 1
fi

# Keep a few target paths as real directories so Stow links their contents
# individually instead of folding the whole directory into one symlink.
unfolded_paths=(
  "$HOME/.codex"
  "$HOME/.local/bin"
  "$HOME/.ssh"
)

for p in "${unfolded_paths[@]}"; do
  mkdir -p "$p"
done

stow --restow "${dirs[@]}" --dir "$HOME/scripts/config" --target "$HOME" --adopt --verbose
stow --restow "${dirs[@]}" --dir "$HOME/scripts/bin" --target "$HOME" --adopt --verbose

# Restore the content of the repo since we run with `--adopt`...
if [ -d "$HOME/scripts/.git" ]; then
  git -C "$HOME/scripts" restore .
  git -C "$HOME/scripts" clean --force -d -- config bin
fi

"$lib_dir/render-codex-config"
