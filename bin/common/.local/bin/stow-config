#!/bin/bash

set -eu -o pipefail

if ! git -C "$HOME/scripts" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "ERROR: $HOME/scripts must be a git repository before running stow-config"
  exit 1
fi

# Don't support running stow if the git repo is dirty (since we're using `--adopt`)
if [ -n "$(git -C "$HOME/scripts" status --porcelain)" ]; then
  echo "ERROR: $HOME/scripts is dirty, please commit changes before running stow-config"
  exit 1
fi

dirs=(common)

# Platform-specific stuff
plat="$(uname)"
if [ "$plat" = "Linux" ]; then
  dirs+=(linux)
elif [ "$plat" = "Darwin" ]; then
  dirs+=(macos)
fi

# OpenAI stuff
if [ -d "$HOME/scripts/config/openai" ]; then
  dirs+=(openai)
fi

stow --no-folding "${dirs[@]}" --dir "$HOME/scripts/config" --target "$HOME" --adopt --verbose
stow --no-folding "${dirs[@]}" --dir "$HOME/scripts/bin" --target "$HOME" --adopt --verbose

# Restore the content of the repo since we run with `--adopt`...
git -C "$HOME/scripts" restore .
git -C "$HOME/scripts" clean --force -d -- config bin

stow --restow --no-folding "${dirs[@]}" --dir "$HOME/scripts/config" --target "$HOME" --verbose
stow --restow --no-folding "${dirs[@]}" --dir "$HOME/scripts/bin" --target "$HOME" --verbose

# Post-processing for a few things...
"$HOME/.codex/bin/render-config"
