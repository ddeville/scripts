#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" && pwd)"
source "$script_dir/../lib/rcodex.bash"

usage() {
  cat <<'EOF'
Usage: rcodex-stop <host>

Stop a remote Codex app-server started by rcodex.
EOF
}

die() {
  echo "rcodex-stop: $*" >&2
  exit 1
}

remote_stop_script() {
  cat <<EOF
$(rcodex_remote_common_script)

if [[ ! -f "\$pid_file" ]]; then
  echo "rcodex-stop: no pid file at \$pid_file" >&2
  exit 0
fi

server_pid=\$(cat "\$pid_file")
case "\$server_pid" in
  ''|*[!0-9]*)
    echo "rcodex-stop: invalid pid file: \$pid_file" >&2
    exit 1
    ;;
esac

if kill "\$server_pid" 2>/dev/null; then
  rm -f "\$pid_file"
  echo "rcodex-stop: signaled remote Codex app-server pid \$server_pid" >&2
else
  rm -f "\$pid_file"
  echo "rcodex-stop: pid \$server_pid was not running; removed stale pid file" >&2
fi
EOF
}

if [[ ${1-} == "-h" || ${1-} == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -eq 1 ]] || {
  usage >&2
  die "host is required"
}

if [[ $1 == -* ]]; then
  usage >&2
  die "host is required"
fi

host=$1
script=$(remote_stop_script)
rcodex_run_remote "rcodex-stop" "stop remote Codex app-server" "$host" "$script" print || exit 1
