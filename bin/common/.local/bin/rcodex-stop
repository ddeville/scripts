#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" && pwd)"
source "$script_dir/../lib/rcodex.bash"

usage() {
  cat <<'EOF'
Usage: rcodex-stop <host>

Stop a remote Codex app-server started by rcodex.

Environment:
  REMOTE_PORT  Remote app-server port; default: 17338

Examples:
  rcodex-stop host
  REMOTE_PORT=17339 rcodex-stop host
EOF
}

die() {
  echo "rcodex: $*" >&2
  exit 1
}

remote_stop_script() {
  cat <<EOF
if [[ ! -f "\$pid_file" ]]; then
  echo "rcodex: no pid file at \$pid_file" >&2
  exit 0
fi

server_pid=\$(cat "\$pid_file")
case "\$server_pid" in
  ''|*[!0-9]*)
    echo "rcodex: invalid pid file: \$pid_file" >&2
    exit 1
    ;;
esac

if kill "\$server_pid" 2>/dev/null; then
  rm -f "\$pid_file"
  echo "rcodex: signaled remote codex app-server pid \$server_pid" >&2
else
  rm -f "\$pid_file"
  echo "rcodex: pid \$server_pid was not running; removed stale pid file" >&2
fi
EOF
}

if [[ ${1-} == "-h" || ${1-} == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -eq 1 ]] || {
  usage >&2
  die "host is required"
}

if [[ $1 == -* ]]; then
  usage >&2
  die "host is required"
fi

host=$1
script=$(remote_stop_script)
RCODEX_PRINT_REMOTE_OUTPUT=1 rcodex_run_remote "stop remote codex app-server" "$host" "$script" || exit 1
