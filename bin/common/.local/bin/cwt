#!/bin/bash

set -eu -o pipefail

script_dir="$(cd -- "$(dirname -- "$(realpath -- "${BASH_SOURCE[0]}")")" && pwd)"
source "$script_dir/../lib/cw.bash"

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "Usage: cwt <feature> [base-branch]"
  exit 1
fi

if [ -z "${GIT_SRC_WORKTREE_DIR-}" ]; then
  echo "GIT_SRC_WORKTREE_DIR is not set." >&2
  exit 1
fi

if [ ! -d "$GIT_SRC_WORKTREE_DIR" ]; then
  echo "GIT_SRC_WORKTREE_DIR is not a directory: $GIT_SRC_WORKTREE_DIR" >&2
  exit 1
fi

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux is not installed." >&2
  exit 1
fi

if [ -z "${EDITOR-}" ]; then
  echo "EDITOR is not set." >&2
  exit 1
fi

if ! command -v codex >/dev/null 2>&1; then
  echo "codex is not installed." >&2
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$repo_root" ]; then
  echo "cwt must be run inside a Git repository." >&2
  exit 1
fi

feature_name="$1"
base_ref="${2-}"

if [[ $feature_name == */* ]]; then
  echo "Feature name must not contain /: $feature_name" >&2
  exit 1
fi

if [ -z "$base_ref" ]; then
  base_ref="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's@^origin/@@')"
  if [ -z "$base_ref" ]; then
    echo "Could not determine the default branch from refs/remotes/origin/HEAD." >&2
    exit 1
  fi
fi

if ! git rev-parse --verify --quiet "${base_ref}^{commit}" >/dev/null; then
  echo "Base branch does not exist: $base_ref" >&2
  exit 1
fi

branch_name="$(cw_branch_name "$feature_name")"
repo_name="$(cw_repo_name "$repo_root")"
repo_worktree_dir="$GIT_SRC_WORKTREE_DIR/$repo_name"
worktree_path="$repo_worktree_dir/$feature_name"

session_name="$(cw_session_name "$repo_name" "$feature_name")"

printf -v codex_command 'codex fork --all --cd %q' "$worktree_path"

if [ -e "$worktree_path" ]; then
  echo "Worktree path already exists: $worktree_path" >&2
  exit 1
fi

if git rev-parse --verify --quiet "$branch_name" >/dev/null; then
  echo "Branch already exists: $branch_name" >&2
  exit 1
fi

if tmux has-session -t "$session_name" 2>/dev/null; then
  echo "tmux session already exists: $session_name" >&2
  exit 1
fi

mkdir -p "$repo_worktree_dir"

git worktree add -b "$branch_name" "$worktree_path" "$base_ref"

tmux new-session -s "$session_name" -n repo -d -c "$worktree_path"
tmux new-window -t "$session_name:" -n editor -d -c "$worktree_path" "$EDITOR"
tmux new-window -t "$session_name:" -n codex -d -c "$repo_root" "$codex_command"
tmux set-option -t "$session_name" @display_name "$feature_name"
tmux select-window -t "$session_name:codex"

echo "Created worktree:"
echo "  path: $worktree_path"
echo "  branch: $branch_name"
echo "  base: $base_ref"
echo "  tmux: $session_name"

if [ -n "${TMUX-}" ]; then
  tmux switch-client -t "$session_name"
else
  tmux attach-session -t "$session_name"
fi
