#!/bin/bash

set -eu -o pipefail

if [[ $# -ne 3 ]]; then
  echo "usage: ${0##*/} <preferred-key> <allowed-signers> <fallback-agent-sock>" >&2
  exit 2
fi

preferred_key=$1
allowed_signers=$2
fallback_sock=$3

if [[ -z ${SSH_AUTH_SOCK:-} || ! -S ${SSH_AUTH_SOCK:-} || ${SSH_AUTH_SOCK:-} == /private/tmp/com.apple.launchd.* ]]; then
  export SSH_AUTH_SOCK="$fallback_sock"
fi

if ! agent_keys=$(ssh-add -L 2>/dev/null); then
  echo "No SSH signing keys are available from the active agent." >&2
  exit 1
fi
agent_key_tokens=$(awk 'NF >= 2 { print $1 " " $2 }' <<<"$agent_keys")

emit_key() {
  printf 'key::%s\n' "$1"
}

agent_has_key() {
  grep -Fqx "$1" <<<"$agent_key_tokens"
}

if [[ -r $preferred_key ]]; then
  read -r key_type key_blob _ <"$preferred_key"
  preferred_pub="$key_type $key_blob"

  if agent_has_key "$preferred_pub"; then
    emit_key "$preferred_pub"
    exit 0
  fi
fi

if [[ -r $allowed_signers ]]; then
  while read -r _ key_type key_blob _; do
    [[ -n ${key_type:-} && $key_type != \#* && -n ${key_blob:-} ]] || continue

    signing_key="$key_type $key_blob"
    if agent_has_key "$signing_key"; then
      emit_key "$signing_key"
      exit 0
    fi
  done <"$allowed_signers"

  echo "No SSH signing key from the active agent is listed in $allowed_signers." >&2
  exit 1
fi

key_count=$(wc -l <<<"$agent_key_tokens")
if [[ $key_count -eq 1 ]]; then
  emit_key "$agent_key_tokens"
  exit 0
fi

echo "No unambiguous SSH signing key is available from the active agent." >&2
echo "Add the forwarded key to $allowed_signers, or expose only one key in the agent." >&2
exit 1
