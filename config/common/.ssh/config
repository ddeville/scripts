#### Personal

Host *.home.kattungar.net *.lab.kattungar.net
    ForwardAgent yes
    Compression no

Host ddeville.me
    ForwardAgent yes

Match host "*.home.kattungar.net,*.lab.kattungar.net,ddeville.me,github.com,gitlab.com,bitbucket.com" exec ~/.ssh/ssh-use-1p-agent
    IdentitiesOnly yes
    IdentityFile ~/.ssh/id_personal.pub

#### OpenAI

Match all
    Include config_openai

#### Catch-all

# See comment in `ssh-use-1p-agent` for more info about what this all means.
Match host * exec ~/.ssh/ssh-use-1p-agent
    IdentityAgent ~/.1password/agent.sock
